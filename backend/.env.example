# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/parliwatch

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Groq — transcription (get key at console.groq.com)
GROQ_API_KEY=gsk_...

# Anthropic — summarization
ANTHROPIC_API_KEY=sk-ant-...

# Cost controls
MONTHLY_GROQ_SPEND_CAP=50.00
MONTHLY_ANTHROPIC_SPEND_CAP=50.00

# App
SECRET_KEY=change-me-to-a-random-string
CORS_ORIGINS=http://localhost:3000
